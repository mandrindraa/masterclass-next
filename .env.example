# ─── Database ─────────────────────────────────────────────────────────────────
# Replace with your actual PostgreSQL connection string
DATABASE_URL=""

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=50

# ─── Seeding ──────────────────────────────────────────────────────────────────
# Override defaults for the seed script
SEED_SURVEILLANT_EMAIL=""
SEED_SURVEILLANT_PASSWORD=""
# Set to "true" to create sample academic year, subjects, class
SEED_SAMPLE_DATA="false"
